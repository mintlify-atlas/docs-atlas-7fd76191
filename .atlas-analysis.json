  "keyFeatures": [
    "Pure functional agent architecture with immutable state",
    "Directive-based effect system separating logic from side effects",
    "OTP runtime integration with GenServer-based AgentServer",
    "Composable plugin system for reusable capabilities",
    "Multiple execution strategies (Direct, FSM) with extensible protocol",
    "Multi-agent orchestration with parent-child hierarchies",
    "Signal routing and CloudEvents-based messaging",
    "Declarative cron scheduling and worker pools",
    "Schema validation with NimbleOptions and Zoi",
    "Built-in persistence, observability, and debugging tools"
  ],
  "publicApiSurface": [
    "Jido.start_agent/3 - Start an agent under supervision",
    "Jido.stop_agent/2 - Stop a running agent",
    "Jido.whereis/2 - Look up agent by ID",
    "Jido.list_agents/1 - List all running agents",
    "Jido.await/3 - Wait for agent completion",
    "Jido.Agent.new/1 - Create agent struct",
    "Jido.Agent.cmd/2 - Execute actions (core operation)",
    "Jido.Agent.set/2 - Update agent state",
    "Jido.Agent.validate/2 - Validate agent state",
    "Jido.AgentServer.start_link/1 - Start agent GenServer",
    "Jido.AgentServer.call/3 - Synchronous signal processing",
    "Jido.AgentServer.cast/2 - Asynchronous signal processing",
    "Jido.AgentServer.state/1 - Get agent server state",
    "use Jido.Agent - Define agent modules",
    "use Jido.Plugin - Define composable plugins",
    "use Jido.Sensor - Define event sensors",
    "Jido.Agent.Directive.Emit - Emit signals",
    "Jido.Agent.Directive.SpawnAgent - Spawn child agents",
    "Jido.Agent.Directive.Schedule - Schedule delayed actions",
    "Jido.Agent.Directive.Stop - Stop agent process",
    "Jido.Agent.Strategy.Direct - Default execution strategy",
    "Jido.Agent.Strategy.FSM - Finite state machine strategy",
    "Jido.Persist.hibernate/2 - Persist agent to storage",
    "Jido.Persist.thaw/3 - Restore agent from storage"
  ]
}
